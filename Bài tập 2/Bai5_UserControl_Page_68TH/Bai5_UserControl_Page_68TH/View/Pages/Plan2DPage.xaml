<Page x:Class="Bai5_UserControl_Page_68TH.View.Pages.Plan2DPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Bai5_UserControl_Page_68TH.View.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Plan2DPage">

    <Grid>
        <Canvas Name="FloorCanvas" Background="#F5F5F5">

            <!-- Tường ngoài -->
            <Rectangle Canvas.Left="20" Canvas.Top="20"
                       Width="760" Height="410"
                       Stroke="Brown" StrokeThickness="3"/>

            <!-- Phòng khách -->
            <Rectangle Canvas.Left="30" Canvas.Top="30"
                       Width="350" Height="180"
                       Stroke="Red" StrokeThickness="2"/>
            <TextBlock Canvas.Left="150" Canvas.Top="110"
                       Text="Living Room" FontWeight="Bold"/>

            <!-- Phòng ngủ -->
            <Rectangle Canvas.Left="400" Canvas.Top="30"
                       Width="350" Height="180"
                       Stroke="Blue" StrokeThickness="2"/>
            <TextBlock Canvas.Left="520" Canvas.Top="110"
                       Text="Bedroom" FontWeight="Bold"/>

            <!-- Bếp -->
            <Rectangle Canvas.Left="30" Canvas.Top="230"
                       Width="350" Height="180"
                       Stroke="Yellow" StrokeThickness="2"/>
            <TextBlock Canvas.Left="150" Canvas.Top="310"
                       Text="Kitchen" FontWeight="Bold"/>

            <!-- WC -->
            <Rectangle Canvas.Left="400" Canvas.Top="230"
                       Width="160" Height="180"
                       Stroke="Green" StrokeThickness="2"/>
            <TextBlock Canvas.Left="440" Canvas.Top="310"
                       Text="WC" FontWeight="Bold"/>

            <!-- Gara -->
            <Rectangle Canvas.Left="580" Canvas.Top="230"
                       Width="170" Height="180"
                       Stroke="Black" StrokeThickness="2"/>
            <TextBlock Canvas.Left="620" Canvas.Top="310"
                       Text="Garage" FontWeight="Bold"/>

        </Canvas>
    </Grid>
</Page>
