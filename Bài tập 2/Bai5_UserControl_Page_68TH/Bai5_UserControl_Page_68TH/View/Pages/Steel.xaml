<Window x:Class="Bai5_UserControl_Page_68TH.View.Pages.Steel"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Bai5_UserControl_Page_68TH.View.Pages"
        mc:Ignorable="d"
        Title="Steel" Height="450" Width="800">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Tiêu đề -->
        <TextBlock Text="KHAI BÁO THÉP CỐT BÊ TÔNG"
                   FontSize="18" FontWeight="Bold"
                   HorizontalAlignment="Center" Margin="0,0,0,10"/>

        <!-- Nội dung -->
        <Grid Grid.Row="1" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <!-- Cột trái -->
            <StackPanel Grid.Column="0" Margin="10">

                <TextBlock Text="Loại cấu kiện"/>
                <ComboBox>
                    <ComboBoxItem Content="Cột"/>
                    <ComboBoxItem Content="Dầm"/>
                    <ComboBoxItem Content="Sàn"/>
                </ComboBox>

                <TextBlock Text="Mác bê tông" Margin="0,10,0,0"/>
                <ComboBox>
                    <ComboBoxItem Content="B20"/>
                    <ComboBoxItem Content="B25"/>
                    <ComboBoxItem Content="B30"/>
                </ComboBox>

                <TextBlock Text="Chiều rộng (mm)" Margin="0,10,0,0"/>
                <TextBox/>

                <TextBlock Text="Chiều cao (mm)" Margin="0,10,0,0"/>
                <TextBox/>

                <TextBlock Text="Chiều dài (mm)" Margin="0,10,0,0"/>
                <TextBox/>

            </StackPanel>

            <!-- Cột phải -->
            <StackPanel Grid.Column="1" Margin="10">

                <TextBlock Text="Thép chủ (dọc)"/>
                <StackPanel Orientation="Horizontal">
                    <TextBox Width="50" Margin="0,0,5,0"/>
                    <TextBlock Text="Ø"/>
                    <TextBox Width="50" Margin="5,0,0,0"/>
                </StackPanel>

                <TextBlock Text="Thép đai" Margin="0,10,0,0"/>
                <StackPanel Orientation="Horizontal">
                    <TextBox Width="50" Margin="0,0,5,0"/>
                    <TextBlock Text="Ø"/>
                    <TextBox Width="50" Margin="5,0,0,0"/>
                </StackPanel>

                <TextBlock Text="Khoảng cách đai (mm)" Margin="0,10,0,0"/>
                <TextBox/>

                <TextBlock Text="Lớp bảo vệ (mm)" Margin="0,10,0,0"/>
                <TextBox/>

                <TextBlock Text="Số lượng thanh thép" Margin="0,10,0,0"/>
                <TextBox/>

            </StackPanel>
        </Grid>

        <!-- Nút -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Tính toán" Width="100" Margin="5"/>
            <Button Content="Reset" Width="100" Margin="5"/>
        </StackPanel>

    </Grid>
</Window>
